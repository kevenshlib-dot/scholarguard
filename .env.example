# =============================================================================
# ScholarGuard — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# ---- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://sguser:sgpass_dev@postgres:5432/scholarguard

# ---- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- MinIO / S3 -------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scholarguard
MINIO_USE_SSL=false

# ---- Qdrant -----------------------------------------------------------------
QDRANT_URL=http://qdrant:6333

# ---- JWT / Auth -------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Local LLM backends (optional) -----------------------------------------
OLLAMA_URL=http://ollama:11434
VLLM_URL=

# ---- External LLM API keys (optional, leave blank if unused) ----------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---- Application ------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# ---- ScholarGuard scoring parameters ----------------------------------------
FORMULA_VERSION=v1.0
PARAM_VERSION=v1.1
